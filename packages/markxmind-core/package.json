{
  "name": "@markxmind/markxmind-core",
  "version": "0.1.1",
  "description": "MarkXMind parser - Parse Markdown-like syntax to XMind mind map data structure.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README_zh-CN.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "markxmind",
    "xmindmark",
    "xmind",
    "mindmap",
    "markdown"
  ],
  "author": "Zhichao (@jinzcdev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinzcdev/markxmind.git"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "nanoid": "^3.3.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
